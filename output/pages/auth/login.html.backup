<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>로그인 - 과일다리</title>
    <link rel="stylesheet" href="../../styles/design-system.css">
    <link rel="stylesheet" href="../../styles/components.css">
    <style>
        /* Login Page Specific Styles */
        .page-container {
            width: 430px;
            margin: 0 auto;
            background: var(--color-white);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Header */
        .login-header {
            padding: var(--space-4);
            position: relative;
        }

        .close-button {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: transparent;
            border: none;
            border-radius: var(--radius-full);
            font-size: 24px;
            cursor: pointer;
            transition: background var(--transition-fast);
        }

        .close-button:active {
            background: var(--color-gray-50);
        }

        /* Logo Section */
        .logo-section {
            padding: var(--space-8) var(--space-4) var(--space-6);
            text-align: center;
        }

        .logo {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #6FCF3F, #5CB82F);
            border-radius: var(--radius-xl);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            margin: 0 auto var(--space-4);
        }

        .brand-name {
            font-size: 24px;
            font-weight: 700;
            color: var(--color-gray-900);
            margin-bottom: var(--space-2);
        }

        .brand-tagline {
            font-size: var(--font-size-sm);
            color: var(--color-gray-600);
        }

        /* Login Form */
        .login-form {
            padding: 0 var(--space-4) var(--space-6);
        }

        .form-group {
            margin-bottom: var(--space-4);
        }

        .form-input {
            width: 100%;
            padding: var(--space-4);
            border: 1px solid var(--color-gray-200);
            border-radius: var(--radius-lg);
            font-size: var(--font-size-base);
            transition: all var(--transition-fast);
        }

        .form-input:focus {
            outline: none;
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(111, 207, 63, 0.1);
        }

        .form-input.error {
            border-color: var(--color-error);
        }

        .error-message {
            font-size: var(--font-size-xs);
            color: var(--color-error);
            margin-top: var(--space-1);
            display: none;
        }

        .error-message.show {
            display: block;
        }

        /* Remember & Find */
        .login-options {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: var(--space-6);
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: var(--space-2);
        }

        .checkbox-wrapper {
            position: relative;
            width: 20px;
            height: 20px;
        }

        .checkbox-input {
            position: absolute;
            opacity: 0;
            cursor: pointer;
        }

        .checkbox-custom {
            position: absolute;
            top: 0;
            left: 0;
            width: 20px;
            height: 20px;
            background: var(--color-white);
            border: 2px solid var(--color-gray-300);
            border-radius: var(--radius-sm);
            transition: all var(--transition-fast);
        }

        .checkbox-input:checked ~ .checkbox-custom {
            background: var(--color-primary);
            border-color: var(--color-primary);
        }

        .checkbox-input:checked ~ .checkbox-custom::after {
            content: '✓';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            font-size: 12px;
            font-weight: bold;
        }

        .remember-label {
            font-size: var(--font-size-sm);
            color: var(--color-gray-700);
            cursor: pointer;
        }

        .find-links {
            display: flex;
            gap: var(--space-3);
        }

        .find-link {
            font-size: var(--font-size-sm);
            color: var(--color-gray-600);
            text-decoration: none;
        }

        .find-divider {
            color: var(--color-gray-300);
        }

        /* Login Button */
        .login-button {
            width: 100%;
            padding: var(--space-4);
            background: var(--color-primary);
            color: var(--color-white);
            border: none;
            border-radius: var(--radius-lg);
            font-size: var(--font-size-md);
            font-weight: 600;
            cursor: pointer;
            transition: all var(--transition-fast);
        }

        .login-button:active {
            transform: scale(0.98);
            background: var(--color-primary-dark);
        }

        .login-button:disabled {
            background: var(--color-gray-300);
            cursor: not-allowed;
        }

        /* Social Login */
        .social-section {
            padding: 0 var(--space-4) var(--space-8);
        }

        .social-divider {
            display: flex;
            align-items: center;
            gap: var(--space-3);
            margin-bottom: var(--space-5);
        }

        .social-divider::before,
        .social-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--color-gray-200);
        }

        .social-divider-text {
            font-size: var(--font-size-sm);
            color: var(--color-gray-500);
        }

        .social-buttons {
            display: flex;
            gap: var(--space-3);
        }

        .social-button {
            flex: 1;
            padding: var(--space-3);
            border: 1px solid var(--color-gray-200);
            border-radius: var(--radius-lg);
            background: var(--color-white);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all var(--transition-fast);
        }

        .social-button:active {
            background: var(--color-gray-50);
            transform: scale(0.98);
        }

        .social-icon {
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .social-button.kakao {
            background: #FEE500;
            border-color: #FEE500;
        }

        .social-button.naver {
            background: #03C75A;
            border-color: #03C75A;
        }

        .social-button.google {
            background: var(--color-white);
        }

        /* Signup Link */
        .signup-section {
            padding: var(--space-4);
            text-align: center;
            margin-top: auto;
            border-top: 1px solid var(--color-gray-100);
        }

        .signup-text {
            font-size: var(--font-size-sm);
            color: var(--color-gray-600);
        }

        .signup-link {
            color: var(--color-primary);
            font-weight: 500;
            text-decoration: none;
            margin-left: var(--space-1);
        }

        /* Loading State */
        .loading {
            position: relative;
            pointer-events: none;
        }

        .loading::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 20px;
            height: 20px;
            margin: -10px 0 0 -10px;
            border: 2px solid var(--color-white);
            border-radius: 50%;
            border-top-color: transparent;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Password Toggle */
        .password-wrapper {
            position: relative;
        }

        .password-toggle {
            position: absolute;
            right: var(--space-4);
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--color-gray-500);
            cursor: pointer;
            font-size: 18px;
            padding: var(--space-2);
        }
    </style>
</head>
<body>
    <div class="page-container">
        <!-- Header -->
        <header class="login-header">
            <button class="close-button" onclick="history.back()">✕</button>
        </header>

        <!-- Logo Section -->
        <div class="logo-section">
            <div class="logo">🍊</div>
            <h1 class="brand-name">과일다리</h1>
            <p class="brand-tagline">신선한 과일로 이어지는 행복한 다리</p>
        </div>

        <!-- Login Form -->
        <form class="login-form" onsubmit="handleLogin(event)">
            <div class="form-group">
                <input
                    type="text"
                    class="form-input"
                    id="username"
                    placeholder="아이디 또는 이메일"
                    required
                >
                <div class="error-message" id="username-error">아이디 또는 이메일을 입력해주세요</div>
            </div>

            <div class="form-group">
                <div class="password-wrapper">
                    <input
                        type="password"
                        class="form-input"
                        id="password"
                        placeholder="비밀번호"
                        required
                    >
                    <button type="button" class="password-toggle" onclick="togglePassword()">
                        <span id="password-icon">👁️</span>
                    </button>
                </div>
                <div class="error-message" id="password-error">비밀번호를 입력해주세요</div>
            </div>

            <div class="login-options">
                <div class="remember-me">
                    <div class="checkbox-wrapper">
                        <input type="checkbox" class="checkbox-input" id="remember">
                        <div class="checkbox-custom"></div>
                    </div>
                    <label for="remember" class="remember-label">자동 로그인</label>
                </div>
                <div class="find-links">
                    <a href="/auth/find-id" class="find-link">아이디 찾기</a>
                    <span class="find-divider">|</span>
                    <a href="/auth/find-password" class="find-link">비밀번호 찾기</a>
                </div>
            </div>

            <button type="submit" class="login-button" id="login-btn">로그인</button>
        </form>

        <!-- Social Login -->
        <div class="social-section">
            <div class="social-divider">
                <span class="social-divider-text">간편 로그인</span>
            </div>
            <div class="social-buttons">
                <button class="social-button kakao" onclick="socialLogin('kakao')">
                    <div class="social-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                            <path d="M12 3C6.477 3 2 6.477 2 10.5c0 2.615 1.824 4.903 4.563 6.186-.2.732-.728 2.665-.744 2.748-.023.108.04.212.144.237.104.025.215-.02.277-.09.806-.917 2.95-3.35 3.31-3.76C10.344 15.937 11.16 16 12 16c5.523 0 10-3.477 10-7.5S17.523 3 12 3z" fill="#000000"/>
                        </svg>
                    </div>
                </button>
                <button class="social-button naver" onclick="socialLogin('naver')">
                    <div class="social-icon">
                        <span style="color: white; font-weight: bold;">N</span>
                    </div>
                </button>
                <button class="social-button google" onclick="socialLogin('google')">
                    <div class="social-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                    </div>
                </button>
            </div>
        </div>

        <!-- Signup Link -->
        <div class="signup-section">
            <span class="signup-text">아직 회원이 아니신가요?</span>
            <a href="/auth/signup" class="signup-link">회원가입</a>
        </div>
    </div>

    <script>
        // Handle login
        function handleLogin(event) {
            event.preventDefault();

            const username = document.getElementById('username').value;
            const password = document.getElementById('password').value;
            const loginBtn = document.getElementById('login-btn');

            // Clear previous errors
            document.querySelectorAll('.form-input').forEach(input => {
                input.classList.remove('error');
            });
            document.querySelectorAll('.error-message').forEach(msg => {
                msg.classList.remove('show');
            });

            // Basic validation
            let hasError = false;

            if (!username) {
                document.getElementById('username').classList.add('error');
                document.getElementById('username-error').classList.add('show');
                hasError = true;
            }

            if (!password) {
                document.getElementById('password').classList.add('error');
                document.getElementById('password-error').classList.add('show');
                hasError = true;
            }

            if (hasError) return;

            // Show loading state
            loginBtn.classList.add('loading');
            loginBtn.disabled = true;
            loginBtn.textContent = '로그인 중...';

            // Simulate login
            setTimeout(() => {
                // Success
                alert('로그인 성공!');
                location.href = '/';
            }, 1500);
        }

        // Toggle password visibility
        function togglePassword() {
            const passwordInput = document.getElementById('password');
            const passwordIcon = document.getElementById('password-icon');

            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                passwordIcon.textContent = '🙈';
            } else {
                passwordInput.type = 'password';
                passwordIcon.textContent = '👁️';
            }
        }

        // Social login
        function socialLogin(provider) {
            const messages = {
                kakao: '카카오 로그인을 시작합니다...',
                naver: '네이버 로그인을 시작합니다...',
                google: '구글 로그인을 시작합니다...'
            };

            alert(messages[provider]);
            // In real app, would redirect to OAuth provider
        }

        // Clear errors on input
        document.querySelectorAll('.form-input').forEach(input => {
            input.addEventListener('input', function() {
                this.classList.remove('error');
                const errorMsg = this.parentElement.querySelector('.error-message') ||
                               this.parentElement.parentElement.querySelector('.error-message');
                if (errorMsg) {
                    errorMsg.classList.remove('show');
                }
            });
        });
    </script>
</body>
</html>