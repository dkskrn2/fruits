<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fruit Commerce Proposal</title>
<style>
:root{--bg:#f5efe5;--paper:#fffaf3;--ink:#1f1a16;--muted:#675f56;--line:rgba(31,26,22,.10);--accent:#cb5b2c;--olive:#556548;--berry:#a14253;--gold:#a97828;--shadow:0 24px 60px rgba(43,31,18,.10);--display:"Iowan Old Style","Palatino Linotype","Apple SD Gothic Neo","Malgun Gothic",serif;--body:"Noto Sans KR","Apple SD Gothic Neo","Malgun Gothic",sans-serif}
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;overflow:hidden;font-family:var(--body);color:var(--ink);background:radial-gradient(circle at 0 0,rgba(203,91,44,.15),transparent 24%),radial-gradient(circle at 100% 0,rgba(85,101,72,.14),transparent 22%),linear-gradient(180deg,#f7f1e7 0,#f2ebdf 100%)}button{font:inherit}
.frame{width:min(1400px,calc(100% - 32px));margin:0 auto}.topbar{position:sticky;top:0;z-index:40;background:rgba(247,241,231,.88);backdrop-filter:blur(14px);border-bottom:1px solid rgba(31,26,22,.08)}.topbar-inner{display:flex;justify-content:space-between;align-items:center;gap:16px;padding:14px 0}.brand{font-size:14px;font-weight:900;letter-spacing:.12em;text-transform:uppercase}.brand span{color:var(--accent)}.topbar-meta{display:flex;align-items:center;gap:12px}.nav{display:flex;flex-wrap:wrap;gap:10px}.nav-btn{padding:10px 14px;border:none;border-radius:999px;background:rgba(31,26,22,.06);color:var(--muted);font-size:12px;font-weight:900;letter-spacing:.02em;cursor:pointer;transition:.2s ease}.nav-btn.is-active,.nav-btn:hover{background:var(--ink);color:#fff}.page-state{display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:999px;background:rgba(31,26,22,.06);font-size:12px;font-weight:900;color:var(--muted)}.page-state strong{color:var(--ink)}.progress{width:110px;height:8px;border-radius:999px;background:rgba(31,26,22,.08);overflow:hidden}.progress-bar{height:100%;width:0%;border-radius:999px;background:linear-gradient(90deg,var(--accent),#f59f76);transition:width .24s ease}
.deck-frame{position:relative;width:min(1480px,calc(100% - 12px));margin:0 auto;padding:10px 0 20px}.deck-frame:before,.deck-frame:after{content:"";position:absolute;top:10px;bottom:20px;width:56px;z-index:5;pointer-events:none}.deck-frame:before{left:-2px;background:linear-gradient(90deg,rgba(242,235,223,.96),rgba(242,235,223,0))}.deck-frame:after{right:-2px;background:linear-gradient(270deg,rgba(242,235,223,.96),rgba(242,235,223,0))}.deck{display:flex;gap:0;overflow-x:auto;scroll-snap-type:x mandatory;scrollbar-width:none;-ms-overflow-style:none}.deck::-webkit-scrollbar{display:none}.slide{flex:0 0 100%;min-width:100%;scroll-snap-align:start;padding:0 14px;opacity:.34;transform:scale(.974);filter:saturate(.86);transition:opacity .25s ease,transform .25s ease,filter .25s ease}.slide.is-active{opacity:1;transform:scale(1);filter:none}.slide-shell{height:calc(100vh - 106px);display:flex;flex-direction:column;justify-content:center;gap:8px;padding:4px 0;overflow:hidden}.slide-meta{display:flex;justify-content:space-between;align-items:center;padding:0 6px 2px}.slide-tag{display:inline-flex;padding:8px 12px;border-radius:999px;background:rgba(31,26,22,.06);color:var(--muted);font-size:11px;font-weight:900;letter-spacing:.12em;text-transform:uppercase}.slide-meta strong{font-family:var(--display);font-size:22px;letter-spacing:-.04em}
.hero{padding:0}.hero-shell,.section-shell{background:rgba(255,250,243,.88);border:1px solid rgba(31,26,22,.08);border-radius:28px;box-shadow:var(--shadow);overflow:hidden}.hero-shell{overflow:hidden}.hero-grid{display:grid;grid-template-columns:1.2fr .8fr}.hero-main{padding:34px} .hero-side{padding:24px;border-left:1px solid rgba(31,26,22,.08);background:linear-gradient(180deg,rgba(85,101,72,.08),rgba(203,91,44,.07))}.eyebrow{display:inline-flex;padding:8px 14px;border-radius:999px;background:rgba(203,91,44,.10);color:var(--accent);font-size:11px;font-weight:900;letter-spacing:.1em;text-transform:uppercase}h1,h2,h3{margin:0}h1{margin-top:16px;font-family:var(--display);font-size:clamp(34px,5.1vw,62px);line-height:.97;letter-spacing:-.05em}.lead{margin:18px 0 0;color:var(--muted);font-size:16px;line-height:1.72}.hero-actions{display:flex;flex-wrap:wrap;gap:10px;margin-top:20px}.chip{padding:10px 14px;border-radius:999px;background:rgba(31,26,22,.06);font-size:12px;font-weight:800}.chip.primary{background:var(--accent);color:#fff}.metric{padding:16px;border-radius:20px;background:rgba(255,255,255,.76);border:1px solid rgba(31,26,22,.08)}.metric+.metric{margin-top:10px}.metric small{display:block;color:var(--muted);font-size:10px;font-weight:900;letter-spacing:.1em;text-transform:uppercase}.metric strong{display:block;margin-top:8px;font-family:var(--display);font-size:26px;letter-spacing:-.05em}.metric p{margin:6px 0 0;color:var(--muted);font-size:12px;line-height:1.56}
.section{padding:0}.section-shell{padding:20px}.section-head{display:flex;justify-content:space-between;align-items:end;gap:16px;margin-bottom:18px}.kicker{color:var(--gold);font-size:11px;font-weight:900;letter-spacing:.12em;text-transform:uppercase}.title{margin-top:8px;font-family:var(--display);font-size:clamp(22px,2.6vw,33px);line-height:1.04;letter-spacing:-.05em}.desc{margin-top:10px;max-width:820px;color:var(--muted);font-size:13px;line-height:1.54}.pill{display:inline-flex;padding:9px 12px;border-radius:999px;background:#dbe4d4;color:var(--olive);font-size:12px;font-weight:900}
.grid-3,.grid-2,.grid-4{display:grid;gap:14px}.grid-3{grid-template-columns:repeat(3,minmax(0,1fr))}.grid-2{grid-template-columns:repeat(2,minmax(0,1fr))}.grid-4{grid-template-columns:repeat(4,minmax(0,1fr))} .card{padding:14px;border-radius:20px;background:rgba(255,255,255,.78);border:1px solid rgba(31,26,22,.08)}.card h3{font-size:18px;letter-spacing:-.03em}.card p{margin:10px 0 0;color:var(--muted);font-size:12px;line-height:1.5}
.board{display:grid;grid-template-columns:1.05fr .95fr;gap:14px} .chart{padding:16px;border-radius:20px;background:rgba(255,255,255,.78);border:1px solid rgba(31,26,22,.08)}.chart h3{font-size:16px}.chart p{margin:7px 0 0;color:var(--muted);font-size:12px;line-height:1.54}.bars{display:grid;gap:10px;margin-top:14px}.bar{display:grid;grid-template-columns:115px 1fr 40px;gap:8px;align-items:center;font-size:12px}.track{height:12px;border-radius:999px;background:rgba(31,26,22,.07);overflow:hidden}.fill{height:100%;border-radius:999px;background:linear-gradient(90deg,var(--accent),#f59f76)}.fill.olive{background:linear-gradient(90deg,var(--olive),#9ab18d)}.fill.berry{background:linear-gradient(90deg,var(--berry),#d98e9d)}.value{text-align:right;color:var(--muted);font-size:12px;font-weight:900}
 .quote{padding:14px;border-radius:18px;background:rgba(255,255,255,.78);border:1px solid rgba(31,26,22,.08)}.quote strong{display:block;font-size:16px;letter-spacing:-.02em}.quote p{margin:8px 0 0;color:var(--muted);font-size:12px;line-height:1.5} .persona{padding:16px;border-radius:22px;background:linear-gradient(180deg,rgba(85,101,72,.10),rgba(255,255,255,.94));border:1px solid rgba(31,26,22,.08)}.persona-tag{display:inline-flex;padding:8px 12px;border-radius:999px;background:rgba(31,26,22,.07);font-size:11px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.persona h3{margin-top:14px;font-family:var(--display);font-size:30px;letter-spacing:-.04em}.persona p{margin:12px 0 0;color:var(--muted);font-size:13px;line-height:1.54}
.compare{display:grid;gap:10px}.compare-row{display:grid;grid-template-columns:138px 1fr 1fr;gap:10px;align-items:center}.compare-label{font-size:13px;font-weight:900}.compare-box{padding:12px 14px;border-radius:16px;border:1px solid rgba(31,26,22,.08);background:rgba(255,255,255,.78);font-size:13px;line-height:1.52}.compare-box.on{background:linear-gradient(180deg,rgba(161,66,83,.10),rgba(255,255,255,.94))}.compare-box.us{background:linear-gradient(180deg,rgba(203,91,44,.11),rgba(255,255,255,.94))}
.table{width:100%;border-collapse:collapse;border-radius:18px;overflow:hidden;background:rgba(255,255,255,.78);border:1px solid rgba(31,26,22,.08)}.table th,.table td{padding:12px 12px;text-align:left;vertical-align:top;border-bottom:1px solid rgba(31,26,22,.08);font-size:12px;line-height:1.52}.table th{background:rgba(85,101,72,.10);color:var(--muted);font-size:11px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.table tr:last-child td{border-bottom:none}
.roadmap{display:grid;gap:12px} .step{display:grid;grid-template-columns:82px 1fr;gap:12px;padding:14px;border-radius:20px;background:rgba(255,255,255,.78);border:1px solid rgba(31,26,22,.08)}.tag{display:inline-flex;align-items:center;justify-content:center;padding:10px;border-radius:14px;background:var(--ink);color:#fff;font-size:11px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.step h3{font-size:18px}.step p{margin:7px 0 0;color:var(--muted);font-size:12px;line-height:1.5}
.footer{padding:10px 0 0;color:var(--muted);font-size:12px;text-align:center}
.tone-1 .slide-tag{background:rgba(203,91,44,.10);color:var(--accent)}.tone-2 .slide-tag{background:rgba(85,101,72,.12);color:var(--olive)}.tone-3 .slide-tag{background:rgba(169,120,40,.12);color:var(--gold)}.tone-4 .slide-tag{background:rgba(161,66,83,.10);color:var(--berry)}.tone-5 .slide-tag{background:rgba(85,101,72,.12);color:var(--olive)}.tone-6 .slide-tag{background:rgba(31,26,22,.08);color:var(--ink)}.tone-7 .slide-tag{background:rgba(203,91,44,.08);color:var(--accent)}
.page-actions{position:fixed;right:20px;bottom:18px;z-index:45;display:flex;gap:10px}.page-action{padding:14px 18px;border:none;border-radius:999px;background:rgba(31,26,22,.88);color:#fff;font-size:13px;font-weight:900;cursor:pointer;box-shadow:var(--shadow)}.page-action[disabled]{opacity:.35;cursor:default}
@media (max-width:1320px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}}
@media (max-width:1100px){body{overflow:auto}.deck-frame{width:min(100%,calc(100% - 10px));padding:10px 0 18px}.deck-frame:before,.deck-frame:after{display:none}.deck{display:block;overflow:visible}.slide{min-width:unset;padding:0 6px;opacity:1;transform:none;filter:none}.slide-shell{height:auto;display:block}.hero-grid,.board,.grid-4,.grid-3,.grid-2{grid-template-columns:1fr}.compare-row,.step{grid-template-columns:1fr}.hero-side{border-left:none;border-top:1px solid rgba(31,26,22,.08)}.page-actions{display:none}}
@media (max-width:760px){.topbar-inner,.section-head{flex-direction:column;align-items:start}.topbar-meta{flex-direction:column;align-items:start}.hero-main,.hero-side,.section-shell{padding:20px}.bar{grid-template-columns:1fr}.nav{gap:8px}.nav-btn{font-size:11px;padding:8px 12px}}
</style>
</head>
<body>
<header class="topbar"><div class="frame topbar-inner"><div class="brand"><span>Fruit</span> Commerce Proposal</div><div class="topbar-meta"><nav class="nav"><button type="button" class="nav-btn is-active" data-slide-target="0">1. ??</button><button type="button" class="nav-btn" data-slide-target="5">2. ??</button><button type="button" class="nav-btn" data-slide-target="13">3. ??</button><button type="button" class="nav-btn" data-slide-target="20">4. ???</button><button type="button" class="nav-btn" data-slide-target="27">5. UX</button><button type="button" class="nav-btn" data-slide-target="32">6. ??</button><button type="button" class="nav-btn" data-slide-target="36">7. ??</button></nav><div class="page-state"><span>Slide</span><strong id="page-state">1 / 32</strong><div class="progress"><div class="progress-bar" id="progress-bar"></div></div></div></div></div></header>
<main class="deck-frame"><div class="deck" id="deck"><section class="slide is-active tone-1" data-slide-index="0" data-chapter="0"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">결론</span><strong>1 / 32</strong></div><section class="hero"><div class="hero-shell"><div class="hero-grid"><div class="hero-main"><div class="eyebrow">Decision-Led Premium Fruit Commerce</div><h1>잘 파는 과일이 아니라<br>잘 고르게 해주는 과일 커머스</h1><p class="lead">온브릭스를 넘기기 위해 같은 언어로 당도 경쟁을 할 필요는 없습니다. 우리가 가져가야 할 축은 <strong>실패 없는 선택</strong>입니다. 실제 소비자 보이스를 보면 온라인 과일 구매의 핵심 문제는 <strong>무엇을 골라야 할지 모르겠다는 불안</strong>, <strong>품질과 선물 실패에 대한 두려움</strong>, <strong>리뷰 신뢰 부족</strong>에 있습니다. 그래서 이 사이트의 얼굴은 <strong>결정 대행형 프리미엄 큐레이션</strong>이어야 합니다.</p><div class="hero-actions"><div class="chip primary">핵심 전략: 결정 대행형 프리미엄 큐레이션</div><div class="chip">운영 기반: B2B/B2C 연결 구조</div><div class="chip">채널 실행: 스마트스토어 최적화</div></div></div><aside class="hero-side"><div class="metric"><small>Core Answer</small><strong>선택 대행</strong><p>누가 언제 왜 이 과일을 사야 하는가를 대신 판단해주는 구조가 필요합니다.</p></div><div class="metric"><small>Primary Target</small><strong>30~49세 여성</strong><p>모바일 장보기와 선물 구매를 주도하고, 품질 실패에 민감한 고객층입니다.</p></div><div class="metric"><small>Winning Axis</small><strong>실패 없는 선택</strong><p>품질, 리뷰, 포장, 배송, 추천 이유를 묶어 안심할 근거를 제공합니다.</p></div></aside></div></div></section></div></section><section class="slide tone-1" data-slide-index="1" data-chapter="0"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">결론</span><strong>2 / 32</strong></div><section class="section" id="decision"><div class="section-shell"><div class="section-head"><div><div class="kicker">Decision Board</div><h2 class="title">핵심 전략이 앞에 서고, 운영 기반과 채널 실행이 뒤를 받쳐야 합니다</h2><div class="desc">기존 문서는 분석 범위는 충분했지만 “무엇이 사이트의 얼굴인가”가 약했습니다. 이제 구조를 분명히 나눠야 합니다. 고객이 체감하는 가치, 공급과 운영, 네이버/스마트스토어 실행 방식이 각각 역할을 가져야 합니다.</div></div><div class="pill">Face, Backbone, Channel</div></div><div class="grid-3"><article class="card"><h3>고객이 보는 얼굴</h3><p>무엇을 사야 할지 모르겠는 고객을 대신해 고르는 서비스. 상황 기반 추천, 취향 기반 추천, 품질 설명 카드가 핵심입니다.</p></article><article class="card"><h3>운영의 등뼈</h3><p>일반가와 도매가 분리, 발주, 재주문, 공급 안정화, B2B 연결 구조가 핵심 전략을 뒤에서 지탱합니다.</p></article><article class="card"><h3>채널에서 파는 방식</h3><p>스마트스토어 제목, 썸네일, 리뷰, 무료배송, N배송 문법을 맞춰 핵심 메시지를 실제 매출로 전환합니다.</p></article></div></div></section></div></section><section class="slide tone-1" data-slide-index="2" data-chapter="0"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">결론</span><strong>3 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Ops Engine</div><h2 class="title">운영 기반은 재고를 돌리는 기능이 아니라 B2B 고객의 고통을 줄이는 엔진이어야 합니다</h2><div class="desc">B2B 고객은 단순히 싸게 사는 것을 원하지 않습니다. 가격이 왜 바뀌는지, 품질이 왜 흔들리는지, 납품이 왜 늦는지, 클레임을 누가 어떻게 처리하는지가 더 중요합니다. 따라서 운영 기반은 재고 배정 로직이면서 동시에 거래 피로를 줄이는 시스템이어야 합니다.</div></div><div class="pill">B2B Pain -> Operating Solution</div></div><div class="grid-3"><article class="card"><h3>가격과 품질 불투명</h3><p>B2B 고객은 거래처별 단가 차이와 품질 편차를 가장 피곤해합니다. 그래서 시세 기준, 등급 기준, 거래처 스펙 기준을 같이 남겨 가격과 품질을 설명 가능하게 만들어야 합니다.</p></article><article class="card"><h3>물량과 납기 불안정</h3><p>정기 납품인데도 물량이 흔들리면 식당, 재판매업체, 호텔 운영이 같이 흔들립니다. B2B 약정 물량을 먼저 잠그고, B2C는 그 잔여 가용분 위에서만 움직여야 합니다.</p></article><article class="card"><h3>발주와 클레임 비효율</h3><p>전화와 메시지 중심 발주는 누락과 오해를 만들고, 기준 없는 클레임 처리는 거래 피로를 키웁니다. 발주 내역, 납기일, 단가, 규격, 클레임 이력이 한 흐름으로 관리돼야 합니다.</p></article></div></div></section></div></section><section class="slide tone-1" data-slide-index="3" data-chapter="0"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">??</span><strong>4 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Ops Engine</div><h2 class="title">운영 기반은 재고를 돌리는 기능이 아니라 B2B 고객의 고통을 줄이는 엔진이어야 합니다</h2><div class="desc">B2B 고객은 단순히 싸게 사는 것을 원하지 않습니다. 가격이 왜 바뀌는지, 품질이 왜 흔들리는지, 납품이 왜 늦는지, 클레임을 누가 어떻게 처리하는지가 더 중요합니다. 따라서 운영 기반은 재고 배정 로직이면서 동시에 거래 피로를 줄이는 시스템이어야 합니다.</div></div><div class="pill">B2B Pain -> Operating Solution</div></div><table class="table"<table class="table" style="margin-top:16px"><thead><tr><th>B2B 고객 고통</th><th>운영으로 해결하는 방식</th><th>실제 재고/발주 반영</th></tr></thead><tbody><tr><td>가격이 불투명하다</td><td>시세, 등급, 물량, 납품 조건 기준으로 가격 변동 이유를 설명</td><td>거래처별 가격표와 등급별 단가 기록</td></tr><tr><td>품질이 들쭉날쭉하다</td><td>입고 즉시 크기, 당도, 외관 기준으로 등급화하고 거래처별 스펙에 맞게 배정</td><td>호텔, 식당, 재판매업체, 가공업체 스펙 분리</td></tr><tr><td>물량이 불안정하다</td><td>B2B 약정 수량과 납기일을 먼저 잠그고 나머지를 B2C에 개방</td><td>B2B 확보량 자동 차감 후 B2C 판매 가능 수량 반영</td></tr><tr><td>주문 커뮤니케이션이 비효율적이다</td><td>발주 내역, 납기, 수량, 규격, 단가, 재주문 이력을 같은 흐름으로 관리</td><td>발주 누락과 담당자 변경 리스크 감소</td></tr><tr><td>클레임 기준이 모호하다</td><td>파손, 규격 미달, 납기 지연, 수량 누락별 대응 시간과 보상 원칙 사전 합의</td><td>클레임 발생률을 다음 배정 로직과 거래처 관리에 반영</td></tr></tbody></table></div></section></div></section><section class="slide tone-1" data-slide-index="4" data-chapter="0"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">??</span><strong>5 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Ops Engine</div><h2 class="title">운영 기반은 재고를 돌리는 기능이 아니라 B2B 고객의 고통을 줄이는 엔진이어야 합니다</h2><div class="desc">B2B 고객은 단순히 싸게 사는 것을 원하지 않습니다. 가격이 왜 바뀌는지, 품질이 왜 흔들리는지, 납품이 왜 늦는지, 클레임을 누가 어떻게 처리하는지가 더 중요합니다. 따라서 운영 기반은 재고 배정 로직이면서 동시에 거래 피로를 줄이는 시스템이어야 합니다.</div></div><div class="pill">B2B Pain -> Operating Solution</div></div><table class="table"<div class="grid-4"><article class="card"><h3>재고 배정</h3><p>선물형은 예약 우선, 일상형은 일일 가용 우선, B2B는 약정 수량 우선으로 잠급니다.</p></article><article class="card"><h3>발주 동기화</h3><p>새벽 입고 후 즉시 등급화하고, 거래처 확보량을 먼저 차감한 뒤 B2C 판매 수량을 자동 반영합니다.</p></article><article class="card"><h3>거래처별 스펙 분리</h3><p>호텔은 외관과 시간, 식당은 신선도와 반복 납기, 가공업체는 단가와 대량 공급이 우선입니다.</p></article><article class="card"><h3>잔여 재고 처리</h3><p>규격 미스와 잔여 재고는 실속형, 가공용, 특가 번들로 즉시 재배치해 폐기율을 낮춥니다.</p></article></div></div></section></div></section><section class="slide tone-2" data-slide-index="4" data-chapter="1"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">시장</span><strong>5 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Market Reading</div><h2 class="title">시장은 품질을 보지만, 결제는 신뢰와 맥락에서 일어납니다</h2><div class="desc">리서치 전체를 합치면 과일 구매는 품질만으로 끝나지 않습니다. 품질 언어는 진입 조건이고, 실제 결제는 후기, 배송, 선물 적합성, 추천 이유가 완성합니다.</div></div><div class="pill">KREI 요약 + 내부 리서치</div></div><div class="board"><div class="chart"><h3>구매 결정 기본 축</h3><p>리서치 로그에 정리한 KREI 요약 수치입니다.</p><div class="bars"><div class="bar"><div>맛/당도</div><div class="track"><div class="fill" style="width:39.9%"></div></div><div class="value">39.9</div></div><div class="bar"><div>가격</div><div class="track"><div class="fill olive" style="width:30.5%"></div></div><div class="value">30.5</div></div><div class="bar"><div>신선도</div><div class="track"><div class="fill berry" style="width:23%"></div></div><div class="value">23.0</div></div></div></div><div class="chart"><h3>실무 해석</h3><p>실제 온라인 전환에서는 아래 4가지가 같이 작동합니다.</p><div class="grid-2"><div class="card"><h3>품질 언어</h3><p>당도, 품종, 식감, 산지, 등급</p></div><div class="card"><h3>신뢰 언어</h3><p>후기, CS, 환불, 배송 안전성</p></div><div class="card"><h3>상황 언어</h3><p>선물, 집용, 아이 간식, 가성비, 프리미엄</p></div><div class="card"><h3>채널 언어</h3><p>제목, 썸네일, 무료배송, N배송, 리뷰 볼륨</p></div></div></div></div></div></section></div></section><section class="slide tone-2" data-slide-index="6" data-chapter="1"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">??</span><strong>7 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Market Contraction</div><h2 class="title">과일 시장은 죽는 것이 아니라, 기존 소비 방식이 무너지고 있습니다</h2><div class="desc">과일 섭취량 감소는 사람들이 과일을 싫어해서라기보다 비싸고, 불편하고, 생활 구조가 바뀌었고, 선물·의례 수요가 약해졌고, 대체재가 많아졌기 때문으로 보는 것이 맞습니다. 따라서 해결책은 과일을 더 많이 팔자는 구호가 아니라, 과일 소비의 마찰을 줄이는 설계여야 합니다.</div></div><div class="pill">Friction, Not Rejection</div></div><div class="board"><div class="chart"><h3>?? ??? ?? ??</h3><p>?? ??? ?? ???? ?? ??? ?????.</p><div class="grid-3"><div class="card"><h3>가격 부담</h3><p>일상형 소비에서는 과일이 건강식보다 비싼 간식처럼 느껴질 수 있습니다.</p></div><div class="card"><h3>가구 구조 변화</h3><p>1인 가구와 맞벌이 증가로 대용량, 손질형, 보관 어려운 과일이 불리해졌습니다.</p></div><div class="card"><h3>섭취 불편</h3><p>껍질, 씨, 손질, 보관, 무름, 음식물쓰레기 부담이 실제 소비 장벽으로 작동합니다.</p></div></div></div></div></section></div></section><section class="slide tone-2" data-slide-index="7" data-chapter="1"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">??</span><strong>8 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Market Contraction</div><h2 class="title">과일 시장은 죽는 것이 아니라, 기존 소비 방식이 무너지고 있습니다</h2><div class="desc">과일 섭취량 감소는 사람들이 과일을 싫어해서라기보다 비싸고, 불편하고, 생활 구조가 바뀌었고, 선물·의례 수요가 약해졌고, 대체재가 많아졌기 때문으로 보는 것이 맞습니다. 따라서 해결책은 과일을 더 많이 팔자는 구호가 아니라, 과일 소비의 마찰을 줄이는 설계여야 합니다.</div></div><div class="pill">Friction, Not Rejection</div></div><div class="board"><div class="chart"><h3>?? ??? ?? ??</h3><p>?? ??? ?? ???? ?? ??? ?????.</p><div class="grid-3"><div class="card"><h3>선물·의례 수요 약화</h3><p>차례 간소화와 명절 소비 변화로 사과·배 중심 전통 수요가 약해지고 있습니다.</p></div><div class="card"><h3>대체재 증가</h3><p>수입과일, 냉동과일, 컷팅과일, 디저트, 건강 간식이 모두 경쟁자입니다.</p></div><div class="card"><h3>건강 인식 양면화</h3><p>성인층에서는 당류, 다이어트, 혈당 부담 인식이 함께 커지고 있습니다.</p></div></div></div></div></section></div></section><section class="slide tone-2" data-slide-index="8" data-chapter="1"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">??</span><strong>9 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Market Contraction</div><h2 class="title">과일 시장은 죽는 것이 아니라, 기존 소비 방식이 무너지고 있습니다</h2><div class="desc">과일 섭취량 감소는 사람들이 과일을 싫어해서라기보다 비싸고, 불편하고, 생활 구조가 바뀌었고, 선물·의례 수요가 약해졌고, 대체재가 많아졌기 때문으로 보는 것이 맞습니다. 따라서 해결책은 과일을 더 많이 팔자는 구호가 아니라, 과일 소비의 마찰을 줄이는 설계여야 합니다.</div></div><div class="pill">Friction, Not Rejection</div></div><div class="board"><div class="chart"><h3>?? ??? ?? ??</h3><p>?? ?? ??? ????? ?? 5??? ??? ???? ???.</p><div class="grid-3"><div class="card"><h3>가격 이원화</h3><p>선물형 프리미엄과 일상형 실속 SKU를 분리해 모두를 프리미엄으로 밀지 않습니다.</p></div><div class="card"><h3>포맷 혁신</h3><p>소포장, 세척형, 바로 먹는 구성, 짧은 소비주기 SKU가 필요합니다.</p></div><div class="card"><h3>상황별 메시지</h3><p>부모님 선물용, 아이 간식용, 아침 과일용, 자기관리용처럼 상황으로 팔아야 합니다.</p></div></div></div></div></section></div></section><section class="slide tone-2" data-slide-index="9" data-chapter="1"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">??</span><strong>10 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Market Contraction</div><h2 class="title">과일 시장은 죽는 것이 아니라, 기존 소비 방식이 무너지고 있습니다</h2><div class="desc">과일 섭취량 감소는 사람들이 과일을 싫어해서라기보다 비싸고, 불편하고, 생활 구조가 바뀌었고, 선물·의례 수요가 약해졌고, 대체재가 많아졌기 때문으로 보는 것이 맞습니다. 따라서 해결책은 과일을 더 많이 팔자는 구호가 아니라, 과일 소비의 마찰을 줄이는 설계여야 합니다.</div></div><div class="pill">Friction, Not Rejection</div></div><div class="board"><div class="chart"><h3>?? ??? ?? ??</h3><p>?? ?? ??? ????? ?? 5??? ??? ???? ???.</p><div class="grid-3"><div class="card"><h3>건강 메시지 재설계</h3><p>성인에게는 고당도보다 가볍게 먹기 좋은 양, 소량 섭취, 자기관리 문법이 더 맞습니다.</p></div><div class="card"><h3>실패 감소 운영</h3><p>무름, 파손, 맛 편차, 후기 불신을 줄이는 운영 설계가 재구매 회복의 핵심입니다.</p></div><div class="card"><h3>세그먼트 분리</h3><p>선물형, 가족 건강 반복구매형, 1인 가구 자기관리형을 각각 다른 문제 해결 시장으로 봐야 합니다.</p></div></div></div></div></section></div></section><section class="slide tone-2" data-slide-index="6" data-chapter="1"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">시장</span><strong>7 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Market Contraction</div><h2 class="title">과일 시장은 죽는 것이 아니라, 기존 소비 방식이 무너지고 있습니다</h2><div class="desc">과일 섭취량 감소는 사람들이 과일을 싫어해서라기보다 비싸고, 불편하고, 생활 구조가 바뀌었고, 선물·의례 수요가 약해졌고, 대체재가 많아졌기 때문으로 보는 것이 맞습니다. 따라서 해결책은 과일을 더 많이 팔자는 구호가 아니라, 과일 소비의 마찰을 줄이는 설계여야 합니다.</div></div><div class="pill">Friction, Not Rejection</div></div><table class="table" style="margin-top:16px"><thead><tr><th>세그먼트</th><th>해결하는 문제</th><th>시장 역할</th><th>실행 포인트</th></tr></thead><tbody><tr><td>선물형</td><td>선물 실패 공포</td><td>진입 시장</td><td>브랜드와 전환 문법 확보</td></tr><tr><td>가족 건강 반복구매형</td><td>비싸고 애매한 일상 과일 구매</td><td>핵심 확장 시장</td><td>실속형, 소포장, 반복구매 SKU 강화</td></tr><tr><td>1인 가구 자기관리형</td><td>먹고 싶지만 부담스럽고 귀찮은 문제</td><td>실험 시장</td><td>고당도보다 저부담 섭취 문법 테스트</td></tr></tbody></table></div></section></div></section><section class="slide tone-2" data-slide-index="7" data-chapter="1"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">시장</span><strong>8 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Consumer Voice</div><h2 class="title">실제 소비자 보이스가 말하는 핵심은 좋은 과일보다 실패 없는 선택입니다</h2><div class="desc">소비자 보이스를 보면 만족과 불만은 모두 품질 그 자체보다 “결과적으로 안심할 수 있었는가”에 묶여 있습니다. 선물은 더 그렇습니다. 그래서 이 사이트는 제품 카탈로그보다 선택 보조와 신뢰 설계가 앞에 와야 합니다.</div></div><div class="pill">리뷰 요약 + App Store + 기사 기반</div></div><div class="grid-2"><article class="quote"><strong>과즙이 팡팡 터진다</strong><p>온브릭스 감귤 리뷰 요약에서 반복된 만족 표현. 맛의 강도뿐 아니라 기대한 경험을 했다는 신호로 읽힙니다.</p></article><article class="quote"><strong>개별포장이라 무르지 않는다</strong><p>스마트스토어 등록 후기 표본에서는 포장 안정성과 무손상 도착이 반복적으로 언급됐습니다. 신선식품은 맛만큼 포장이 중요합니다.</p></article><article class="quote"><strong>받은 분도 만족했다</strong><p>선물세트 후기에서 핵심은 과일 스펙이 아니라, 받는 사람이 만족했는지와 포장, 도착 상태였습니다.</p></article><article class="quote"><strong>썩은 과일 / 물러진 과일</strong><p>불만 리뷰는 한 번만 나와도 타격이 큽니다. 품질 실패 공포와 리뷰 민감도가 이 카테고리의 본질입니다.</p></article></div></div></section></div></section><section class="slide tone-2" data-slide-index="8" data-chapter="1"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">시장</span><strong>9 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Consumer Voice</div><h2 class="title">실제 소비자 보이스가 말하는 핵심은 좋은 과일보다 실패 없는 선택입니다</h2><div class="desc">소비자 보이스를 보면 만족과 불만은 모두 품질 그 자체보다 “결과적으로 안심할 수 있었는가”에 묶여 있습니다. 선물은 더 그렇습니다. 그래서 이 사이트는 제품 카탈로그보다 선택 보조와 신뢰 설계가 앞에 와야 합니다.</div></div><div class="pill">리뷰 요약 + App Store + 기사 기반</div></div><div class="board" style="margin-top:16px"><div class="chart"><h3>소비자 페인포인트 강도</h3><p>리뷰 신호와 내부 소비자 문서를 합친 상대 중요도입니다.</p><div class="bars"><div class="bar"><div>선택 피로</div><div class="track"><div class="fill" style="width:92%"></div></div><div class="value">92</div></div><div class="bar"><div>품질 실패 공포</div><div class="track"><div class="fill berry" style="width:89%"></div></div><div class="value">89</div></div><div class="bar"><div>선물 실패 공포</div><div class="track"><div class="fill olive" style="width:85%"></div></div><div class="value">85</div></div><div class="bar"><div>리뷰 불신</div><div class="track"><div class="fill" style="width:82%"></div></div><div class="value">82</div></div><div class="bar"><div>가격 납득 필요</div><div class="track"><div class="fill olive" style="width:76%"></div></div><div class="value">76</div></div></div></div><div class="chart"><h3>전략 해석</h3><p>이 신호를 그대로 풀면 핵심 전략의 방향은 명확합니다.</p><div class="grid-2"><div class="card"><h3>상황부터 묻기</h3><p>상품보다 먼저 누구를 위한 과일인지 묻습니다.</p></div><div class="card"><h3>설명 강화</h3><p>당도 수치보다 왜 실패 확률이 낮은지 설명합니다.</p></div><div class="card"><h3>SKU 분리</h3><p>선물형과 일상형 SKU를 언어부터 분리합니다.</p></div><div class="card"><h3>신뢰 장치</h3><p>리뷰를 장식이 아니라 핵심 전환 장치로 설계합니다.</p></div></div></div></div></div></section></div></section><section class="slide tone-3" data-slide-index="13" data-chapter="2"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">??</span><strong>14 / 43</strong></div><section class="section" id="target"><div class="section-shell"><div class="section-head"><div><div class="kicker">Primary Target</div><h2 class="title">주타겟은 30~49세 여성 모바일 장보기·선물 구매 주도층입니다</h2><div class="desc">이 고객은 과일 전문가는 아니지만 실패는 싫어합니다. 가족용 과일과 선물용 과일을 모두 살 수 있고, 모바일 구매에 익숙하며, 품질과 포장과 후기 신뢰에 민감합니다.</div></div><div class="pill">Family + Gift + Mobile</div></div><div class="board"><div class="board"><article class="persona"><div class="persona-tag">Primary Persona</div><h3>좋은 선택을 하고 싶다</h3><p>아이 간식도 사야 하고, 부모님께 보낼 선물도 챙겨야 합니다. 과일 품종을 깊게 알지는 않지만, 실패한 선택은 기억합니다. 이 고객에게 필요한 것은 더 많은 상품 수가 아니라 지금 상황에서 무엇이 맞는지 대신 판단해주는 서비스입니다.</p></article><div class="grid-2"><div class="card"><h3>Need</h3><p>내 취향과 상황에 맞는 과일을 빠르게 추천받고 싶다.</p></div><div class="card"><h3>Fear</h3><p>비싸게 샀는데 맛이 없거나, 선물이 애매하거나, 포장이 망가질까 봐 걱정된다.</p></div></div></div></div></section></div></section><section class="slide tone-3" data-slide-index="14" data-chapter="2"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">??</span><strong>15 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Primary Target</div><h2 class="title">주타겟은 30~49세 여성 모바일 장보기·선물 구매 주도층입니다</h2><div class="desc">이 고객은 과일 전문가는 아니지만 실패는 싫어합니다. 가족용 과일과 선물용 과일을 모두 살 수 있고, 모바일 구매에 익숙하며, 품질과 포장과 후기 신뢰에 민감합니다.</div></div><div class="pill">Family + Gift + Mobile</div></div><div class="board"><div class="grid-2"><div class="card"><h3>Trigger</h3><p>후기 신뢰, 포장 설명, 도착 상태, 추천 이유가 명확하면 결제 확률이 올라간다.</p></div><div class="card"><h3>Message</h3><p>선물 실패 없는 과일, 아이 간식용 실패 없는 선택, 대신 골라주는 큐레이션이 유효하다.</p></div></div></div></section></div></section><section class="slide tone-3" data-slide-index="15" data-chapter="2"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">??</span><strong>16 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Target Architecture</div><h2 class="title">선물형은 초기 전략, 아이 대상 구독형은 장기 전략으로 가져가는 편이 더 맞습니다</h2><div class="desc">선물형은 문제 강도와 메시지 선명도가 가장 높아 빠르게 브랜드를 세우기에 유리합니다. 반대로 아이 대상 구독형은 부모의 건강 간식, 과자 대체, 정기 섭취 니즈와 연결돼 반복구매와 LTV를 만들기 좋습니다. 따라서 선물은 시작점, 아이 구독은 장기 확장 전략으로 보는 것이 더 적절합니다.</div></div><div class="pill">Acquisition, Retention, LTV</div></div><div class="grid-4"><div class="grid-2"><article class="card"><h3>초기/단기 전략: 선물형</h3><p>실패 공포가 가장 선명하고, 포장·도착·받는 사람 만족이라는 전환 장치를 설계하기 쉽습니다. 객단가가 높아 초기 메시지 검증과 브랜드 구축에 유리합니다.</p></article><article class="card"><h3>중기 확장: 가족 건강 반복구매</h3><p>가정용 반복구매형과 아이 간식/가족 건강형은 사실상 같은 시장으로 보는 편이 맞습니다. 장보기, 아이 간식, 아침 과일, 믿고 재구매가 하나의 운영 언어로 묶입니다.</p></article></div></div></section></div></section><section class="slide tone-3" data-slide-index="16" data-chapter="2"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">??</span><strong>17 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Target Architecture</div><h2 class="title">선물형은 초기 전략, 아이 대상 구독형은 장기 전략으로 가져가는 편이 더 맞습니다</h2><div class="desc">선물형은 문제 강도와 메시지 선명도가 가장 높아 빠르게 브랜드를 세우기에 유리합니다. 반대로 아이 대상 구독형은 부모의 건강 간식, 과자 대체, 정기 섭취 니즈와 연결돼 반복구매와 LTV를 만들기 좋습니다. 따라서 선물은 시작점, 아이 구독은 장기 확장 전략으로 보는 것이 더 적절합니다.</div></div><div class="pill">Acquisition, Retention, LTV</div></div><div class="grid-4"><div class="grid-2"><article class="card"><h3>장기 전략: 아이 대상 구독형</h3><p>부모의 건강 간식, 과자 대체, 정기 섭취 습관과 연결되는 장기 전략입니다. 선물형으로 들어온 고객을 생활 침투형 반복구매로 전환하는 역할을 맡습니다.</p></article><article class="card"><h3>별도 실험 시장: 1인가구 자기관리형</h3><p>고당도 프리미엄보다 건강, 체중관리, 부담 적은 섭취 문법이 맞는 시장입니다. 핵심 축이 아니라 별도 검증 트랙으로 다뤄야 합니다.</p></article></div></div></section></div></section><section class="slide tone-3" data-slide-index="11" data-chapter="2"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">타겟</span><strong>12 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Target Architecture</div><h2 class="title">선물형은 초기 전략, 아이 대상 구독형은 장기 전략으로 가져가는 편이 더 맞습니다</h2><div class="desc">선물형은 문제 강도와 메시지 선명도가 가장 높아 빠르게 브랜드를 세우기에 유리합니다. 반대로 아이 대상 구독형은 부모의 건강 간식, 과자 대체, 정기 섭취 니즈와 연결돼 반복구매와 LTV를 만들기 좋습니다. 따라서 선물은 시작점, 아이 구독은 장기 확장 전략으로 보는 것이 더 적절합니다.</div></div><div class="pill">Acquisition, Retention, LTV</div></div><table class="table" style="margin-top:16px"><thead><tr><th>판단 항목</th><th>선물형</th><th>가족 건강 반복구매형</th><th>아이 대상 구독형</th></tr></thead><tbody><tr><td>전략 역할</td><td>초기/단기</td><td>중기 확장</td><td>장기 Retention</td></tr><tr><td>핵심 가치</td><td>실패 없는 선물</td><td>믿고 사는 건강한 일상 과일</td><td>부모가 챙기기 쉬운 건강 습관</td></tr><tr><td>메시지 선명도</td><td>가장 선명함</td><td>선명하지만 덜 감정적</td><td>부모 메시지 설계 필요</td></tr><tr><td>반복구매 가능성</td><td>낮음</td><td>높음</td><td>가장 높음</td></tr><tr><td>현재 적합도</td><td>즉시 실행</td><td>선물형 뒤에 확장</td><td>승자 SKU 확보 후 오픈</td></tr></tbody></table><div class="desc" style="margin-top:16px">현재 구조를 더 단순화하면 <code>선물형 = Acquisition</code>, <code>아이 구독형 = Retention / LTV</code>입니다. 다만 이것이 <code>1인가구 자기관리형</code> 실험 시장이 사라진다는 뜻은 아닙니다. 현재 구조는 <code>선물형 = 단기</code>, <code>아이 구독형 = 장기</code>, <code>1인가구 자기관리형 = 별도 실험</code>으로 이해하는 편이 가장 정확합니다. 또한 아이 구독형은 바로 열지 않고, 승자 SKU 확보, 소포장과 보관 설계, 품질 일관성, 부모 메시지 검증, 운영 안정화가 선행돼야 합니다.</div></div></section></div></section><section class="slide tone-3" data-slide-index="12" data-chapter="2"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">타겟</span><strong>13 / 32</strong></div><section class="section" id="strengths"><div class="section-shell"><div class="section-head"><div><div class="kicker">Our Strengths</div><h2 class="title">이 사이트가 부각해야 할 강점은 제품 스펙이 아니라 선택 구조입니다</h2><div class="desc">기존 제안의 내용은 충분했지만, 사이트의 강점은 덜 보였습니다. 이제는 사이트의 존재 이유를 4개 축으로 선명하게 잡아야 합니다.</div></div><div class="pill">Selection, Explainability, Trust, Operations</div></div><div class="grid-4"><article class="card"><h3>실패 없는 선택 대행</h3><p>누가 먹는지, 언제 먹는지, 선물인지 집용인지부터 묻고 추천합니다.</p></article><article class="card"><h3>설명 가능한 프리미엄</h3><p>당도, 식감, 용도, 포장, 배송 기준, 후기 근거를 한 세트로 보여줍니다.</p></article><article class="card"><h3>선물형·일상형 분리</h3><p>선물용 보자기 SKU와 가정용 반복구매 SKU를 언어부터 분리해 각각 최적화합니다.</p></article><article class="card"><h3>운영 데이터 해자</h3><p>B2B 발주와 반복구매 데이터를 함께 쌓아 공급, 재고, 가격, 폐기를 안정화합니다.</p></article></div></div></section></div></section><section class="slide tone-3" data-slide-index="13" data-chapter="2"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">타겟</span><strong>14 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Positioning</div><h2 class="title">도매를 전면에 내세우지 말고, 직송의 전문성으로 번역해야 합니다</h2><div class="desc">고객에게 도매는 싸다는 장점도 주지만, 대량 구매와 투박함의 선입견도 줍니다. 그래서 이 사이트는 도매상이 아니라 새벽 경매장에서 가장 좋은 과일을 골라오는 과일 큐레이터로 보여야 합니다.</div></div><div class="pill">From 도매업자 To 과일 큐레이터</div></div><div class="grid-3"><article class="card"><h3>새벽 경매장 페르소나</h3><p>오늘 경매장에서 가장 상태가 좋은 과일을 선별하는 전문가라는 이미지를 전면에 둡니다.</p></article><article class="card"><h3>직송의 전문성</h3><p>유통 단계를 줄였다는 가격 논리보다, 선별과 신선함을 지키는 구조라는 점을 강조합니다.</p></article><article class="card"><h3>메시지 문장</h3><p>새벽 경매장의 활기를 식탁까지. 유통 단계를 줄인 만큼, 신선함은 늘렸습니다.</p></article></div></div></section></div></section><section class="slide tone-4" data-slide-index="14" data-chapter="3"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">차별화</span><strong>15 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Trust Content</div><h2 class="title">신뢰는 설명이 아니라 시각화된 검수 과정에서 생깁니다</h2><div class="desc">과일은 이번에도 맛있을까라는 불안을 늘 동반합니다. 그래서 상세페이지는 상품 소개가 아니라 신뢰를 시각화하는 화면이 되어야 합니다.</div></div><div class="pill">Brix, Origin, Inspection</div></div><div class="grid-3"><article class="card"><h3>당도/품질 카드</h3><p>브릭스 수치, 식감, 용도, 산지, 선별 기준을 상세페이지 상단에서 바로 보여줍니다.</p></article><article class="card"><h3>산지/경매장 스토리</h3><p>경매 현장, 산지, 선별 장면을 숏폼이나 짧은 이미지 시퀀스로 보여줘 직송의 전문성을 체감하게 합니다.</p></article><article class="card"><h3>3단계 선별 시그니처</h3><p>크기, 당도, 외관의 3단계 검수 과정을 브랜드 표준 매뉴얼처럼 반복 노출합니다.</p></article></div></div></section></div></section><section class="slide tone-4" data-slide-index="15" data-chapter="3"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">차별화</span><strong>16 / 32</strong></div><section class="section" id="benchmark"><div class="section-shell"><div class="section-head"><div><div class="kicker">Benchmark</div><h2 class="title">온브릭스는 강하지만, 같은 언어로 따라가면 안 됩니다</h2><div class="desc">온브릭스는 이미 당도, 선별 기준, 선물 패키지, 브랜드 기억도에서 강합니다. 우리가 이길 수 있는 지점은 더 달다가 아니라 더 잘 고르게 해준다는 체계입니다.</div></div><div class="pill">당도 경쟁이 아니라 선택 대행 경쟁</div></div><div class="compare"><div class="compare-row"><div class="compare-label">핵심 언어</div><div class="compare-box on">당도, 선별, 보자기, 프리미엄 선물 경험</div><div class="compare-box us">상황, 취향, 실패 없는 선택, 설명 가능한 프리미엄</div></div><div class="compare-row"><div class="compare-label">고객 질문</div><div class="compare-box on">얼마나 당도 높은가?</div><div class="compare-box us">지금 누구에게 어떤 과일을 사야 하는가?</div></div><div class="compare-row"><div class="compare-label">전환 장치</div><div class="compare-box on">보자기, 구성, 후기, 중량, 프리미엄 패키지</div><div class="compare-box us">추천 이유, 품질 설명 카드, 리뷰 신뢰, 포장과 도착 상태 근거</div></div><div class="compare-row"><div class="compare-label">확장 방향</div><div class="compare-box on">프리미엄 선물과 브랜드 경험</div><div class="compare-box us">선물 + 일상 + B2B 운영 데이터까지 연결되는 구조</div></div></div></div></section></div></section><section class="slide tone-4" data-slide-index="16" data-chapter="3"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">차별화</span><strong>17 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Pain to Solution</div><h2 class="title">페인포인트를 바로 해결하는 화면과 상품 전략이 필요합니다</h2><div class="desc">핵심 전략은 슬로건이 아닙니다. 소비자 페인포인트를 실제 화면 구조와 상품 운영으로 번역해야 합니다.</div></div></div><table class="table"><thead><tr><th>소비자 문제</th><th>해결 방식</th><th>사이트에서 보여줄 요소</th></tr></thead><tbody><tr><td>뭘 사야 할지 모르겠다</td><td>선택 대행형 추천</td><td>상황별 진입, 취향별 추천, 누구를 위한 과일인가 섹션</td></tr><tr><td>품질 실패가 두렵다</td><td>설명 가능한 프리미엄</td><td>당도, 식감, 산지, 포장, 배송 기준을 한 카드에서 설명</td></tr><tr><td>선물 실패가 두렵다</td><td>선물형 전환 장치 강화</td><td>보자기, 메시지, 후기, 도착 상태, 포장 근거 강조</td></tr><tr><td>리뷰를 믿기 어렵다</td><td>리뷰 신뢰 장치 설계</td><td>좋은 후기만이 아니라 운영 기준과 대응 원칙 공개</td></tr><tr><td>가격이 비싸 보인다</td><td>납득 가능한 설명</td><td>왜 이 상품인지, 어떤 상황에 맞는지, 실패 가능성을 어떻게 낮췄는지 설명</td></tr></tbody></table></div></section></div></section><section class="slide tone-4" data-slide-index="23" data-chapter="3"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">???</span><strong>24 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Gift Failure Conversion</div><h2 class="title">선물 실패 공포는 자극보다 안심 설계로 전환해야 합니다</h2><div class="desc">과일 선물에서 고객이 두려워하는 것은 단순히 맛이 아닙니다. 받는 사람 반응, 포장 첫인상, 도착 상태, 일정 실패, 그리고 내가 잘못 고른 사람처럼 보일 수 있다는 불안이 함께 작동합니다. 따라서 공포를 키우기보다 실패 원인을 먼저 설명하고, 그 실패를 줄이는 장치를 보여줘야 전환이 일어납니다.</div></div><div class="pill">Fear to Assurance</div></div><div class="board"><div class="chart"><h3>?? ???? ?? ??</h3><p>??? ??? ?? 5?? ???? ?? ???? ???.</p><div class="bars"><div class="bar"><div>?? ?? ??</div><div class="track"><div class="fill berry" style="width:94%"></div></div><div class="value">94</div></div><div class="bar"><div>?? ??? ??</div><div class="track"><div class="fill" style="width:90%"></div></div><div class="value">90</div></div><div class="bar"><div>??/?? ??</div><div class="track"><div class="fill olive" style="width:91%"></div></div><div class="value">91</div></div><div class="bar"><div>?? ??</div><div class="track"><div class="fill" style="width:84%"></div></div><div class="value">84</div></div><div class="bar"><div>?? ?? ???</div><div class="track"><div class="fill olive" style="width:80%"></div></div><div class="value">80</div></div></div></div></div></section></div></section><section class="slide tone-4" data-slide-index="24" data-chapter="3"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">???</span><strong>25 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Gift Failure Conversion</div><h2 class="title">선물 실패 공포는 자극보다 안심 설계로 전환해야 합니다</h2><div class="desc">과일 선물에서 고객이 두려워하는 것은 단순히 맛이 아닙니다. 받는 사람 반응, 포장 첫인상, 도착 상태, 일정 실패, 그리고 내가 잘못 고른 사람처럼 보일 수 있다는 불안이 함께 작동합니다. 따라서 공포를 키우기보다 실패 원인을 먼저 설명하고, 그 실패를 줄이는 장치를 보여줘야 전환이 일어납니다.</div></div><div class="pill">Fear to Assurance</div></div><div class="board"><div class="chart"><h3>?? ??</h3><p>??? ?????? ?? ??? ?? ??? ??? ???.</p><div class="grid-2"><div class="card"><h3>1. ?? ???</h3><p>??? ??? ?? ??? ?? ?? ??? ?? ????? ?? ????.</p></div><div class="card"><h3>2. ?? ?? ???</h3><p>??, ??? ??, ?? ??, ?? ??? ?? ?? ????? ?????.</p></div><div class="card"><h3>3. ?? ??</h3><p>??? ??, ??? ??, ????? ??, ??? ?? ??? ??? ?????.</p></div><div class="card"><h3>4. ???? ??</h3><p>?? ?? ??, ?? ? ??, ?? ?? ? ?? ??? ?? ??? ?????.</p></div></div></div></div></section></div></section><section class="slide tone-4" data-slide-index="25" data-chapter="3"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">???</span><strong>26 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Gift Failure Conversion</div><h2 class="title">선물 실패 공포는 자극보다 안심 설계로 전환해야 합니다</h2><div class="desc">과일 선물에서 고객이 두려워하는 것은 단순히 맛이 아닙니다. 받는 사람 반응, 포장 첫인상, 도착 상태, 일정 실패, 그리고 내가 잘못 고른 사람처럼 보일 수 있다는 불안이 함께 작동합니다. 따라서 공포를 키우기보다 실패 원인을 먼저 설명하고, 그 실패를 줄이는 장치를 보여줘야 전환이 일어납니다.</div></div><div class="pill">Fear to Assurance</div></div><table class="table"<table class="table" style="margin-top:16px"><thead><tr><th>실제 적용 장치</th><th>과일에 적용하는 방식</th><th>예시 문장</th></tr></thead><tbody><tr><td>받는 사람 기준 퀵필터</td><td>부모님, 감사 인사, 아이 있는 집, 실패 적은 첫 선물로 진입시킴</td><td>부모님 선물용 추천 받기</td></tr><tr><td>선물 안심 배지</td><td>무손상 도착 후기 다수, 선물 만족 후기 다수, 개별포장, 도착일 맞춤 응대</td><td>무손상 도착 후기 많은 세트</td></tr><tr><td>후기 배치 원칙</td><td>도착 상태, 받는 사람 반응, 맛, 재구매 순서로 후기 재배치</td><td>부모님이 좋아하셨다 / 깨끗하게 도착했다</td></tr><tr><td>실패 방지형 CTA</td><td>구매하기 대신 안심 중심 CTA 사용</td><td>선물 실패 적은 세트 보기</td></tr><tr><td>선물 전용 안전장치</td><td>도착일 메모, 메시지 카드, 출고 전 상태 점검, 도착 이상 우선 응대</td><td>도착 이상 시 선물 전담 CS 우선 응대</td></tr></tbody></table></div></section></div></section><section class="slide tone-4" data-slide-index="26" data-chapter="3"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">???</span><strong>27 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Gift Failure Conversion</div><h2 class="title">선물 실패 공포는 자극보다 안심 설계로 전환해야 합니다</h2><div class="desc">과일 선물에서 고객이 두려워하는 것은 단순히 맛이 아닙니다. 받는 사람 반응, 포장 첫인상, 도착 상태, 일정 실패, 그리고 내가 잘못 고른 사람처럼 보일 수 있다는 불안이 함께 작동합니다. 따라서 공포를 키우기보다 실패 원인을 먼저 설명하고, 그 실패를 줄이는 장치를 보여줘야 전환이 일어납니다.</div></div><div class="pill">Fear to Assurance</div></div><table class="table"<div class="grid-2"><article class="card"><h3>사과/배 혼합 세트</h3><p>부모님 선물과 감사 선물 맥락이 강해 선물 실패 방지 메시지가 가장 잘 작동합니다.</p></article><article class="card"><h3>샤인머스캣 세트</h3><p>프리미엄 인식이 이미 있어 포장 안정성과 고급감 문법을 붙이기 좋습니다.</p></article><article class="card"><h3>감귤 프리미엄형</h3><p>반복구매 후기와 선물 만족 후기를 함께 쌓으며 안심형 상품으로 키우기 좋습니다.</p></article><article class="card"><h3>딸기 품종형</h3><p>적용은 가능하지만 신선도 리스크가 커서 메시지를 더 정교하게 다뤄야 합니다.</p></article></div></div></section></div></section><section class="slide tone-5" data-slide-index="27" data-chapter="4"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">UX</span><strong>28 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Service Layer</div><h2 class="title">대형 플랫폼이 못하는 디테일한 케어로 서비스 차별화를 만듭니다</h2><div class="desc">서비스는 많을수록 좋은 것이 아닙니다. 핵심 전략에 직접 기여하는 것만 남겨야 합니다.</div></div><div class="pill">Care, Guarantee, Packaging</div></div><div class="grid-4"><div class="grid-2"><article class="card"><h3>조건부 맛 보장제</h3><p>맛없으면 100% 환불 문구를 그대로 쓰기보다, 품질 기준 미달과 파손, 무름 등에 대한 조건부 보상 정책으로 시작합니다.</p></article><article class="card"><h3>과일 정기 구독</h3><p>구독은 지금 당장 여는 서비스가 아니라, 아이 대상 장기 전략으로 보는 편이 맞습니다. 선물형으로 고객을 확보한 뒤 건강 간식, 과자 대체, 정기 섭취 습관을 만드는 방향으로 확장해야 합니다.</p></article></div></div></section></div></section><section class="slide tone-5" data-slide-index="28" data-chapter="4"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">UX</span><strong>29 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Service Layer</div><h2 class="title">대형 플랫폼이 못하는 디테일한 케어로 서비스 차별화를 만듭니다</h2><div class="desc">서비스는 많을수록 좋은 것이 아닙니다. 핵심 전략에 직접 기여하는 것만 남겨야 합니다.</div></div><div class="pill">Care, Guarantee, Packaging</div></div><div class="grid-4"><div class="grid-2"><article class="card"><h3>용도별 소분 구성</h3><p>1인 가구용 실속 세트, 가정용 반복구매 세트, 선물용 프리미엄 세트처럼 도매의 대용량 이미지를 깨는 패키징이 필요합니다.</p></article><article class="card"><h3>패키징과 동봉 카드</h3><p>보관 가이드, 후숙 팁, 오늘 이 과일을 고른 이유를 담은 카드와 친환경 완충재는 전문가 이미지를 완성합니다.</p></article></div></div></section></div></section><section class="slide tone-5" data-slide-index="20" data-chapter="4"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">UX</span><strong>21 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Experience Design</div><h2 class="title">고객 경험은 과일을 받는 순간과 먹는 과정까지 설계되어야 합니다</h2><div class="desc">신선식품에서는 결제 직전의 설득보다 도착 상태와 동봉 커뮤니케이션이 더 오래 기억됩니다. 선물형과 일상형은 포장 언어도 분리해야 합니다.</div></div><div class="pill">Packaging, Storage, Repeat</div></div><div class="grid-3"><article class="card"><h3>패키징 원칙</h3><p>도착 상태가 브랜드 경험의 첫인상입니다. 친환경 완충재와 종이 중심 포장은 건강하고 자연친화적인 이미지를 강화합니다.</p></article><article class="card"><h3>동봉 커뮤니케이션</h3><p>사과는 분리 보관, 후숙 후 더 달다 같은 보관 가이드와 오늘 이 과일을 고른 이유를 담은 짧은 전문가 메모를 함께 보냅니다.</p></article><article class="card"><h3>재구매 유도</h3><p>배송 완료 후 같은 취향의 대체 과일과 가정용 실속 SKU를 연결해 선물형 구매를 일상형 반복구매로 전환합니다.</p></article></div></div></section></div></section><section class="slide tone-5" data-slide-index="30" data-chapter="4"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">UX</span><strong>31 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Decision UX</div><h2 class="title">결정 대행은 카피가 아니라 실제 화면 구조로 구현되어야 합니다</h2><div class="desc">브릭스 수치만 앞세우는 상세페이지로는 선택 피로를 해결할 수 없습니다. 고객 상황과 취향을 먼저 묻고, 추천 이유가 수치보다 앞에 와야 합니다.</div></div><div class="pill">Situation, Taste, Hierarchy</div></div><div class="grid-2"><div class="grid-2"><article class="card"><h3>의사결정 보조 도구</h3><p>상황 필터는 선물, 아이 간식, 집용, 보관 기간 같은 질문으로 시작하고, 취향 필터는 당도 위주, 식감 위주, 산미 강도 같은 기준으로 이어집니다.</p></article><article class="card"><h3>운영 필터</h3><p>바로 먹을지, 보관 기간이 긴 것이 좋은지, 가족용인지 1인용인지까지 반영해 추천 SKU를 좁혀야 합니다.</p></article></div></div></section></div></section><section class="slide tone-5" data-slide-index="31" data-chapter="4"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">UX</span><strong>32 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Decision UX</div><h2 class="title">결정 대행은 카피가 아니라 실제 화면 구조로 구현되어야 합니다</h2><div class="desc">브릭스 수치만 앞세우는 상세페이지로는 선택 피로를 해결할 수 없습니다. 고객 상황과 취향을 먼저 묻고, 추천 이유가 수치보다 앞에 와야 합니다.</div></div><div class="pill">Situation, Taste, Hierarchy</div></div><div class="grid-2"><div class="grid-2"><article class="card"><h3>상세페이지 정보 위계</h3><p>첫 화면에는 왜 이 과일이 실패 없는 선택인지 카드가 먼저 나오고, 그 다음 블록에 추천 이유, 그 다음에 브릭스와 산지와 포장 정보가 따라와야 합니다.</p></article><article class="card"><h3>리뷰 배치 원칙</h3><p>맛있다는 표현보다 무손상 도착, 부모님 만족, 개별포장, 재구매 같은 문장을 상단 가까이에 노출해야 전환력이 높아집니다.</p></article></div></div></section></div></section><section class="slide tone-6" data-slide-index="22" data-chapter="5"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">검증</span><strong>23 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Trust and KPI</div><h2 class="title">신뢰는 CS 기준과 KPI가 숫자로 관리될 때 완성됩니다</h2><div class="desc">과일 커머스에서 고객은 완벽을 기대하지 않습니다. 대신 문제가 생겼을 때 얼마나 빠르고 일관되게 대응하는지를 봅니다.</div></div><div class="pill">SLA, Retention, Review Quality</div></div><div class="grid-3"><article class="card"><h3>실행 가능한 SLA</h3><p>파손과 무름은 24시간 내 사진 접수 후 재배송 또는 환불, 품질 기준 미달은 부분 환불 또는 적립 보상처럼 기준을 미리 정해둬야 합니다.</p></article><article class="card"><h3>LTV 전환</h3><p>선물형은 Acquisition, 아이 대상 구독형은 Retention / LTV 구조로 봐야 합니다. 따라서 선물형 고객을 가정용 실속 SKU와 부모용 구독 제안으로 연결하는 흐름이 필요합니다.</p></article><article class="card"><h3>성공 지표</h3><p>재구매율, 리뷰 4.8 이상, 반품률 2% 미만, 선물형 도착 이슈율 1% 미만, 24시간 내 1차 응답 같은 숫자가 필요합니다.</p></article></div></div></section></div></section><section class="slide tone-6" data-slide-index="23" data-chapter="5"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">검증</span><strong>24 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Business Model</div><h2 class="title">도매 우위는 무조건 할인에 쓰지 말고 신뢰와 운영 품질에 먼저 투자해야 합니다</h2><div class="desc">도매 기반의 장점은 고객에게는 신선함이고 사업자에게는 마진입니다. 초기에는 그 우위를 가격 인하보다 검수, 포장, CS, 콘텐츠 제작에 더 많이 써야 브랜드가 남습니다.</div></div><div class="pill">Margin, Trust, Repeat</div></div><div class="grid-3"><article class="card"><h3>도매 우위의 사용처</h3><p>가격 경쟁은 일상형 SKU에서 제한적으로 사용하고, 선물형 SKU는 신뢰와 경험에 투자합니다. 초기 우위는 싸게 파는 것보다 잘 운영하는 데 써야 합니다.</p></article><article class="card"><h3>LTV 구조</h3><p>선물형은 객단가와 브랜드 신뢰를 만들고, 일상형은 반복구매와 LTV를 키웁니다. B2B는 물량 안정화와 원가·재고 방어 역할을 맡습니다.</p></article><article class="card"><h3>실행 전 숫자 검증</h3><p>최소 4개 SKU에 대해 매입가, 포장비, 배송비, 보상률, 공헌이익을 계산해야 합니다. 이 계산이 없으면 좋은 전략도 사업으로는 불안정합니다.</p></article></div></div></section></div></section><section class="slide tone-6" data-slide-index="24" data-chapter="5"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">검증</span><strong>25 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Validation Board</div><h2 class="title">이 제안서는 전략적으로 타당하지만, 사업 계획서로는 아직 조건부입니다</h2><div class="desc">브랜딩, 소비자 문제 정의, 제품 방향은 통과했습니다. 반대로 재무 검증, 운영 용량, 스마트스토어 직접 표본, 온브릭스 대비 정량 기준은 더 보강해야 합니다. 따라서 현재 문서는 방향 결정용으로는 충분히 강하지만, 실행 승인용으로는 보강이 필요합니다.</div></div><div class="pill">Pass, Conditional, Fail</div></div><div class="grid-3"><article class="card"><h3>통과</h3><p>브랜딩, 소비자 문제 정의, 제품/UX 방향, 신뢰/CS 방향은 타당합니다. 특히 도매를 과일 큐레이터로 번역한 포지셔닝과 실패 없는 선택 대행 축은 강합니다.</p></article><article class="card"><h3>조건부</h3><p>마케팅과 소규모 사업 운영은 방향은 맞지만, CAC 한도, 유입 구조, CRM 흐름, 역할 분담과 처리량 기준이 더 필요합니다.</p></article><article class="card"><h3>미통과</h3><p>재무는 아직 미통과입니다. SKU별 공헌이익, 보상률, 폐기율, 무료배송 손익, 포장비와 CS 비용이 숫자로 검증되지 않았습니다.</p></article></div></div></section></div></section><section class="slide tone-6" data-slide-index="25" data-chapter="5"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">검증</span><strong>26 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Validation Board</div><h2 class="title">이 제안서는 전략적으로 타당하지만, 사업 계획서로는 아직 조건부입니다</h2><div class="desc">브랜딩, 소비자 문제 정의, 제품 방향은 통과했습니다. 반대로 재무 검증, 운영 용량, 스마트스토어 직접 표본, 온브릭스 대비 정량 기준은 더 보강해야 합니다. 따라서 현재 문서는 방향 결정용으로는 충분히 강하지만, 실행 승인용으로는 보강이 필요합니다.</div></div><div class="pill">Pass, Conditional, Fail</div></div><table class="table" style="margin-top:16px"><thead><tr><th>핵심 공백</th><th>왜 중요한가</th><th>즉시 보강할 것</th></tr></thead><tbody><tr><td>온브릭스 대비 KPI 기준선 부재</td><td>넘어선다는 목표를 정량으로 증명할 수 없습니다.</td><td>재구매율, 평점, 반품률, 선물형 도착 이슈율, CS 속도 비교표 작성</td></tr><tr><td>SKU별 공헌이익 부재</td><td>선물형과 일상형 중 무엇이 실제로 돈이 되는지 판단할 수 없습니다.</td><td>최소 4개 SKU의 매입가, 포장비, 배송비, 보상률, 공헌이익 계산</td></tr><tr><td>스마트스토어/경쟁사 표본 부족</td><td>현재 카테고리 우선순위와 문법이 시장 대표 패턴인지 확정하기 어렵습니다.</td><td>못난이 사과, 세척 사과, 감귤 직접 표본과 경쟁사 출처 추가</td></tr><tr><td>운영 인력/SOP 부재</td><td>좋은 전략도 소규모 팀이 감당 못하면 무너집니다.</td><td>1인, 2인, 3인 운영 기준의 역할 분담과 하루 처리량 표 작성</td></tr></tbody></table></div></section></div></section><section class="slide tone-7" data-slide-index="36" data-chapter="6"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">??</span><strong>37 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Category Focus</div><h2 class="title">우선 진입 카테고리는 선물과 설명력이 강한 곳부터 시작합니다</h2><div class="desc">스마트스토어 분석과 경쟁사 관찰을 합치면, 이 전략은 설명력이 높은 카테고리에서 먼저 힘을 발휘합니다. 즉 왜 이 과일을 사야 하는가를 말하기 쉬운 카테고리부터 들어가야 합니다.</div></div><div class="pill">Gift First, Daily Repeat Second</div></div><div class="grid-4"><div class="grid-2"><article class="card"><h3>사과/배 혼합 선물세트</h3><p>선물성과 설명력이 강하고, 보자기와 중량, 구성 문법이 이미 검증된 카테고리입니다.</p></article><article class="card"><h3>샤인머스캣 선물세트</h3><p>프리미엄 가격대를 설계하기 좋고, 후기와 포장, 선물 만족 서사가 잘 붙습니다.</p></article></div></div></section></div></section><section class="slide tone-7" data-slide-index="37" data-chapter="6"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">??</span><strong>38 / 43</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Category Focus</div><h2 class="title">우선 진입 카테고리는 선물과 설명력이 강한 곳부터 시작합니다</h2><div class="desc">스마트스토어 분석과 경쟁사 관찰을 합치면, 이 전략은 설명력이 높은 카테고리에서 먼저 힘을 발휘합니다. 즉 왜 이 과일을 사야 하는가를 말하기 쉬운 카테고리부터 들어가야 합니다.</div></div><div class="pill">Gift First, Daily Repeat Second</div></div><div class="grid-4"><div class="grid-2"><article class="card"><h3>딸기 품종형 SKU</h3><p>향, 당도, 산미, 식감 차이를 설명하기 쉬워 추천형 구조와 잘 맞습니다.</p></article><article class="card"><h3>감귤 프리미엄형 SKU</h3><p>타이벡, 제주, Brix, 환불 언어가 이미 강하게 형성돼 있어 설명형 프리미엄에 적합합니다.</p></article></div></div></section></div></section><section class="slide tone-7" data-slide-index="27" data-chapter="6"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">실행</span><strong>28 / 32</strong></div><section class="section" id="roadmap"><div class="section-shell"><div class="section-head"><div><div class="kicker">Roadmap</div><h2 class="title">90일 안에 만들어야 할 것은 기술보다 신뢰되는 선택 구조입니다</h2><div class="desc">초기에는 모든 기능을 만들 필요가 없습니다. 먼저 고객이 이 사이트는 나 대신 골라주는구나라고 느끼게 해야 합니다.</div></div><div class="pill">Message before Complexity</div></div><div class="roadmap"><article class="step"><div class="tag">0-30</div><div><h3>선물형 초기 전략을 정리합니다</h3><p>주타겟 고객용 문장, 선물형 2종과 일상형 2종의 승자 SKU 후보, 상세페이지 설명 카드, 후기 노출 원칙을 정리합니다.</p></div></article><article class="step"><div class="tag">31-60</div><div><h3>선물형을 먼저 검증합니다</h3><p>선물형 1종과 일상형 1종을 우선 런칭하고, 리뷰, CS, 클레임, 재구매 신호를 수집합니다. 동시에 B2B 운영 MVP를 설계합니다.</p></div></article><article class="step"><div class="tag">61-90</div><div><h3>아이 대상 구독형의 조건을 점검합니다</h3><p>취향 테스트 또는 추천 플로우를 도입하고, 카테고리별 승자 SKU를 정리합니다. 이 단계부터 아이 대상 구독형으로 확장 가능한 SKU, 소포장, 보관, 운영 조건을 점검합니다.</p></div></article></div></div></section></div></section><section class="slide tone-7" data-slide-index="28" data-chapter="6"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">실행</span><strong>29 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Guardrails</div><h2 class="title">채널 운영에서 절대 놓치면 안 되는 가드레일</h2><div class="desc">스마트스토어는 상품 등록 창구가 아니라 운영 채널입니다. 후기, 배송, 광고 문구, 클레임 기준이 무너지면 핵심 전략도 설득력을 잃습니다.</div></div></div><div class="grid-3"><div class="card"><h3>문구 가드레일</h3><p>당도 보장, 환불 보장, 프리미엄, 특등급 문구는 실제 기준과 CS 체계가 있을 때만 사용합니다.</p></div><div class="card"><h3>리뷰 가드레일</h3><p>과일 카테고리에서 리뷰는 보조 정보가 아니라 핵심 전환 장치입니다. 신뢰 훼손 운영은 장기적으로 치명적입니다.</p></div><div class="card"><h3>배송 가드레일</h3><p>도착 상태와 포장 품질은 선물과 신선식품에서 브랜드 그 자체입니다. 상품 언어보다 배송 신뢰가 먼저입니다.</p></div></div></div></section></div></section><section class="slide tone-7" data-slide-index="29" data-chapter="6"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">실행</span><strong>30 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Future Ideas</div><h2 class="title">부가 아이디어는 브랜드 자산이 쌓인 뒤 확장 기능으로 붙입니다</h2><div class="desc">아래 아이디어는 방향성은 좋지만, 지금 바로 핵심 전략으로 올리기보다 후속 확장 아이템으로 관리하는 것이 맞습니다.</div></div><div class="pill">Later, Not First</div></div><div class="grid-3"><div class="card"><h3>경매장의 냉정한 관찰자</h3><p>낙선 리스트 공개, 도매가 추이 그래프, 실시간 경매장 라이브 위젯으로 도매의 진정성을 시스템으로 보여주는 방향입니다.</p></div><div class="card"><h3>계절의 기록자</h3><p>과일 빈티지 라벨, 72시간 피크 알림, 테이스팅 노트 카드로 과일을 계절성과 희소성이 있는 경험재로 만드는 방향입니다.</p></div><div class="card"><h3>과일 오마카세 매니저</h3><p>후숙 알림, 제로웨이스트 키트, 당도 커스텀 선택으로 구매 이후 관리와 소비 경험까지 깊게 개입하는 방향입니다.</p></div></div></div></section></div></section><section class="slide tone-7" data-slide-index="30" data-chapter="6"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">실행</span><strong>31 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Final Positioning</div><h2 class="title">최종 포지셔닝은 과일을 잘 파는 곳이 아니라 대신 골라주는 곳입니다</h2><div class="desc">이 프로젝트의 최종 문장은 제품 스펙이 아니라 역할을 설명해야 합니다. 고객은 더 많은 정보보다 실패 없는 선택을 원합니다.</div></div><div class="pill">What We Are</div></div><div class="chart"><h3>포지셔닝 문장</h3><p>과일을 대신 골라주고, 실패 없는 선택으로 증명하는 프리미엄 과일 커머스.</p></div></div></section></div></section><section class="slide tone-7" data-slide-index="31" data-chapter="6"><div class="slide-shell"><div class="slide-meta"><span class="slide-tag">실행</span><strong>32 / 32</strong></div><section class="section"><div class="section-shell"><div class="section-head"><div><div class="kicker">Sources</div><h2 class="title">이 HTML에 반영한 근거 문서와 소비자 보이스 출처</h2></div></div><div class="grid-2"><div class="card"><h3>핵심 전략 문서</h3><p>final_online_fruit_commerce_proposal.md의 최종 전략 구조, 주타겟 고객, 90일 실행안, 검토 반영 섹션을 반영했습니다.</p></div><div class="card"><h3>온브릭스 기준선</h3><p>appendix_onbricks_benchmark.md의 당도, 선물, 브랜드 경험 강점과 빈틈을 반영했습니다.</p></div><div class="card"><h3>경쟁사와 스마트스토어</h3><p>appendix_competitor_benchmark.md와 appendix_smartstore_catalog.md의 대표 SKU, 가격대, 카테고리 우선순위, 실제 후기 표본을 반영했습니다.</p></div><div class="card"><h3>소비자 보이스와 검토</h3><p>appendix_consumer_voice.md의 리뷰 요약과 multi_agent_proposal_review.md의 멀티 에이전트 검토 결과를 반영했습니다.</p></div></div></div></section><div class="footer">Fruit commerce proposal rebuilt from local markdown evidence, benchmark notes, and consumer-voice findings.</div></div></section></div></main>
<div class="page-actions"><button type="button" class="page-action" id="prev-page">이전</button><button type="button" class="page-action" id="next-page">다음</button></div>
<script>
(() => {
  const deck = document.getElementById('deck');
  const slides = Array.from(document.querySelectorAll('.slide'));
  const navButtons = Array.from(document.querySelectorAll('.nav-btn'));
  const state = document.getElementById('page-state');
  const bar = document.getElementById('progress-bar');
  const prev = document.getElementById('prev-page');
  const next = document.getElementById('next-page');
  let currentIndex = 0;

  function clamp(index) {
    return Math.max(0, Math.min(index, slides.length - 1));
  }

  function syncUI(index) {
    currentIndex = clamp(index);
    slides.forEach((slide, i) => slide.classList.toggle('is-active', i === currentIndex));
    const chapter = Number(slides[currentIndex].dataset.chapter);
    navButtons.forEach((button, i) => button.classList.toggle('is-active', i === chapter));
    state.textContent = (currentIndex + 1) + ' / ' + slides.length;
    bar.style.width = (((currentIndex + 1) / slides.length) * 100) + '%';
    prev.disabled = currentIndex === 0;
    next.disabled = currentIndex === slides.length - 1;
  }

  function goToSlide(index) {
    const safeIndex = clamp(index);
    slides[safeIndex].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
    syncUI(safeIndex);
  }

  navButtons.forEach((button) => {
    button.addEventListener('click', () => goToSlide(Number(button.dataset.slideTarget)));
  });

  prev.addEventListener('click', () => goToSlide(currentIndex - 1));
  next.addEventListener('click', () => goToSlide(currentIndex + 1));

  deck.addEventListener('scroll', () => {
    if (window.innerWidth <= 1100) return;
    const nextIndex = Math.round(deck.scrollLeft / deck.clientWidth);
    syncUI(nextIndex);
  }, { passive: true });

  window.addEventListener('keydown', (event) => {
    if (window.innerWidth <= 1100) return;
    if (event.key === 'ArrowRight') goToSlide(currentIndex + 1);
    if (event.key === 'ArrowLeft') goToSlide(currentIndex - 1);
  });

  window.addEventListener('resize', () => syncUI(currentIndex));
  syncUI(0);
})();
</script>
</body>
</html>




